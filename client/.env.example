# === URL del backend (elige UNA, descomenta y comenta las demas) ===

# Local en HTTP  -> arranca back con LOCAL_HTTPS=false y front con VITE_DEV_HTTPS=false
# VITE_API_URL=http://localhost:5500/api/workhub

# Local en HTTPS -> default (npm run dev en ambos); acepta el cert autofirmado una vez
# VITE_API_URL=https://localhost:5500/api/workhub

# Produccion (Railway)
VITE_API_URL=https://workhub-mty-backend-production.up.railway.app/api/workhub

# === Dev server HTTPS ===
# Por defecto el dev server corre en HTTPS (necesario para entrar desde el celular:
# microfono y lector QR requieren contexto seguro). Para HTTP plano en la laptop:
# VITE_DEV_HTTPS=false

# === Periodo de gracia para check-in, en minutos (default 15 segun SRS) ===
VITE_GRACE_MINUTES=15
